{
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "7.2.34"
        },
        "preferred-install": "dist",
        "sort-packages": true
    },
    "require": {
        "php": "^7.2|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5"
    },
    "autoload": {
        "psr-4": {
            "ngyuki\\PHPUnitDescribeIt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
